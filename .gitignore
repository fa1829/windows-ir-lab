# Exported/generated logs (regenerated by the scripts; may contain real host data)
exported_logs/
real_logs/

# Never commit real event log exports — they can contain internal hostnames,
# usernames, and IPs from your machine
*.evtx

__pycache__/
*.pyc
.DS_Store
.vscode/

# Windows alternate-data-stream junk
*:Zone.Identifier
